CAMERA_IP=192.168.8.253
CAMERA_USER=admin
CAMERA_PASSWORD=replace-with-your-camera-password
CAMERA_RTSP_PATH=/tcp/av0_0
CAMERA_RTSP_PORT=10554
CAMERA_ONVIF_PORT=10080
CAMERA_STREAM_RTSP_PATH=/tcp/av0_1
CAMERA_STREAM_FPS=15
CAMERA_STREAM_PROFILE=smooth
CAMERA_STREAM_QUALITY_PATH=/tcp/av0_0
CAMERA_STREAM_SMOOTH_PATH=/tcp/av0_1
CAMERA_STREAM_JPEG_QUALITY=5
CAMERA_STREAM_WIDTH=960
CAMERA_STREAM_SEND_TIMEOUT_SECONDS=0.25
CAMERA_STREAM_KEEP_WARM=true
CAMERA_PTZ_MOVE_SECONDS=0.35
CAMERA_PTZ_SPEED=0.45

FALL_DETECTION_ENABLED=true
FALL_DETECTION_MODEL_ROOT=D:/Program/model/fall_detection
FALL_DETECTION_PYTHON=C:/Users/YOUR_NAME/.conda/envs/AI/python.exe
FALL_DETECTION_EVENT_LOG=D:/Program/health camera/data/fall_events/camera_events.jsonl
FALL_DETECTION_SNAPSHOT_DIR=D:/Program/health camera/data/fall_events/snapshots
FALL_DETECTION_PROFILE=private_scene_fusion_v2
FALL_DETECTION_SPEED_PROFILE=accuracy
FALL_DETECTION_TARGET_DEVICE_MAC=CAMERA-192.168.8.253
FALL_DETECTION_STATUS_LOG_INTERVAL_SECONDS=2
FALL_DETECTION_ROI_ENABLED=true
FALL_DETECTION_ROI_RECT=0.18,0.32,0.82,0.94
FALL_DETECTION_ROI_MIN_OVERLAP=0.50
FALL_DETECTION_FRAME_WIDTH=2304
FALL_DETECTION_FRAME_HEIGHT=1296
FALL_DETECTION_MIN_ALERT_SCORE=0.0
