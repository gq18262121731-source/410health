DATA_MODE=serial
USE_MOCK_DATA=false
SERIAL_ENABLED=true
SERIAL_BAUDRATE=115200
SERIAL_MAC_FILTER=535708000000
SERIAL_AUTO_CONFIGURE=true

# 单采集器模式
SERIAL_PORT=COM3
SERIAL_PACKET_TYPE=5
SERIAL_APPLY_PACKET_TYPE=true
SERIAL_ENABLE_BROADCAST_SOS_OVERLAY=true
SERIAL_RESPONSE_CYCLE_SECONDS=1
SERIAL_BROADCAST_CYCLE_SECONDS=0.5

# 双采集器模式
SERIAL_DUAL_COLLECTOR_ENABLED=false
SERIAL_BROADCAST_PORT=COM4
SERIAL_RESPONSE_PORT=COM3

# 摄像头 / 跌倒检测（按需启用）
CAMERA_IP=
CAMERA_USER=admin
CAMERA_PASSWORD=
CAMERA_SOURCE_MODE=auto
CAMERA_LOCAL_INDEX=0
CAMERA_LOCAL_BACKEND=dshow
CAMERA_RTSP_PORT=10554
CAMERA_RTSP_PATH=/tcp/av0_0
CAMERA_STREAM_RTSP_PATH=/tcp/av0_0
CAMERA_AUDIO_RTSP_PATH=/tcp/av0_1
CAMERA_AUDIO_SAMPLE_RATE=16000
CAMERA_AUDIO_GATEWAY_URL=
CAMERA_SDK_DLL_DIR=
CAMERA_ACTIVEX_CLSID=
CAMERA_ONVIF_PORT=10080
CAMERA_STREAM_PROFILE=quality
CAMERA_STREAM_QUALITY_PATH=/tcp/av0_0
CAMERA_STREAM_SMOOTH_PATH=/tcp/av0_0
CAMERA_STREAM_FPS=12
CAMERA_STREAM_WIDTH=1024
CAMERA_STREAM_JPEG_QUALITY=6
CAMERA_STREAM_KEEP_WARM=true
CAMERA_STREAM_FPS=15
CAMERA_STREAM_JPEG_QUALITY=4
CAMERA_STREAM_SEND_TIMEOUT_SECONDS=1.2
CAMERA_STREAM_WIDTH=0

# Neutral camera source layer. Camera1 falls back to CAMERA_* when left empty.
# These sources only extract video/audio/talk capabilities. UI and algorithms
# should select a camera_id explicitly and stay decoupled from camera hardware.
CAMERA1_NAME=camera1
CAMERA1_IP=
CAMERA1_USER=
CAMERA1_PASSWORD=
CAMERA1_RTSP_PORT=0
CAMERA1_ONVIF_PORT=0
CAMERA1_RTSP_PATH=
CAMERA1_STREAM_RTSP_PATH=
CAMERA1_AUDIO_RTSP_PATH=

# Camera2 falls back to camera_runtime_external/camera_live_config*.json
# when these fields are left empty.
CAMERA2_NAME=camera2
CAMERA2_IP=
CAMERA2_USER=
CAMERA2_PASSWORD=
CAMERA2_RTSP_PORT=0
CAMERA2_ONVIF_PORT=0
CAMERA2_RTSP_PATH=
CAMERA2_STREAM_RTSP_PATH=
CAMERA2_AUDIO_RTSP_PATH=

FALL_DETECTION_ENABLED=false
FALL_DETECTION_MODEL_ROOT=D:\Program\model\fall_detection
FALL_DETECTION_PYTHON=C:\Users\YANG\.conda\envs\AI\python.exe
FALL_DETECTION_PROFILE=private_scene_fusion_v2
FALL_DETECTION_SPEED_PROFILE=accuracy
FALL_DETECTION_THRESHOLD_OVERRIDE=0.65
FALL_DETECTION_PROCESS_EVERY_OVERRIDE=0
FALL_DETECTION_ALERT_RULES_PATH=
FALL_DETECTION_INJURY_RULES_PATH=
FALL_DETECTION_TARGET_DEVICE_MAC=CAMERA-192.168.8.254
FALL_DETECTION_TARGET_ELDER_ID=
FALL_DETECTION_TARGET_FAMILY_IDS=
FALL_DETECTION_EVENT_LOG=./data/fall_events/camera_events.jsonl
FALL_DETECTION_SNAPSHOT_DIR=./data/fall_events/snapshots
FALL_DETECTION_MIN_ALERT_SCORE=0.45
FALL_DETECTION_CONFIRMATION_WINDOW_SECONDS=8
FALL_DETECTION_MIN_CONFIRMED_HITS=2
FALL_DETECTION_MIN_TRACK_AGE_SECONDS=0.8
FALL_DETECTION_HIGH_CONFIDENCE_SCORE=0.72
FALL_DETECTION_MIN_DOWN_SECONDS=1.2
FALL_DETECTION_MIN_BBOX_AREA_RATIO=0.008
FALL_DETECTION_EDGE_MARGIN_RATIO=0.015
FALL_DETECTION_EDGE_PARTIAL_MIN_HEIGHT_RATIO=0.22
FALL_DETECTION_TRACK_STATE_TTL_SECONDS=120
FALL_DETECTION_INCIDENT_REOPEN_SECONDS=20
FALL_DETECTION_MULTIMODAL_ENABLED=true
FALL_DETECTION_MULTIMODAL_PROVIDER=auto
FALL_DETECTION_MULTIMODAL_MIN_SCORE=0.45
FALL_DETECTION_MULTIMODAL_TIMEOUT_SECONDS=45
FALL_DETECTION_ROI_ENABLED=false
FALL_DETECTION_ROI_RECT=
FALL_DETECTION_ROI_MIN_OVERLAP=0.5
FALL_DETECTION_FRAME_WIDTH=2304
FALL_DETECTION_FRAME_HEIGHT=1296

# Pose detection V1 / V1.1
POSE_DETECTION_ENABLED=false
POSE_DETECTION_MODEL_ROOT=D:\ai_helth-main\pose_detection_model_bundle
POSE_DETECTION_PYTHON=C:\Users\13010\anaconda3\envs\helth\python.exe
POSE_DETECTION_PROFILE=default
POSE_DETECTION_PROCESS_EVERY_OVERRIDE=0
POSE_DETECTION_POSE_CONF_THRESHOLD=0.25
POSE_DETECTION_ANALYSIS_WIDTH=960
POSE_DETECTION_EVENT_LOG=./data/pose_events/pose_events.jsonl
POSE_DETECTION_LATEST_JSON=./data/pose_events/latest_pose.json
POSE_DETECTION_SNAPSHOT_DIR=./data/pose_events/snapshots
POSE_DETECTION_STATUS_LOG_INTERVAL_SECONDS=1.5
POSE_DETECTION_RESTART_DELAY_SECONDS=5
POSE_DETECTION_TRACK_MAX_DET=8
POSE_DETECTION_MIN_POSE_SCORE=0.20
POSE_DETECTION_FLOOR_ROI_RECT=
POSE_DETECTION_BED_ROI_RECT=
POSE_DETECTION_SINGLE_FRAME_MODEL_PATH=
# Example for ONNXRuntime CPU acceleration:
# POSE_DETECTION_SINGLE_FRAME_MODEL_PATH=D:\ai_helth-main\fall_detection_model_bundle\yolo11n-pose.onnx
POSE_DETECTION_SINGLE_FRAME_IMGSZ=320
