APP_NAME=AIoT智慧康养健康监测系统
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite+aiosqlite:///data/app.db
REDIS_URL=redis://localhost:6379/0
CHROMA_PATH=./data/chroma

OFFLINE_ONLY_RUNTIME=true
LOCAL_MODEL_ROUTING=task_router
LOCAL_REPORT_ROUTING=fixed
LOCAL_APPROVED_MODELS=qwen3:1.7b,deepseek-r1:1.5b
LOCAL_DEFAULT_MODEL=qwen3:1.7b
LOCAL_REASONING_MODEL=deepseek-r1:1.5b
LOCAL_REPORT_MODEL=deepseek-r1:1.5b

QWEN_API_BASE=
QWEN_API_KEY=
QWEN_MODEL=
QWEN_EMBEDDING_MODEL=
QWEN_RERANK_MODEL=
QWEN_RERANK_API=
QWEN_ENABLE_RERANK=false

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:1.7b

LLM_TIMEOUT_SECONDS=10
DIALOGUE_MAX_PREDICT_TOKENS=320
DIALOGUE_MAX_OUTPUT_CHARS=900
RAG_TIMEOUT_SECONDS=15
RAG_TOP_K=3
RAG_FETCH_K=8
RAG_CHUNK_SIZE=700
RAG_CHUNK_OVERLAP=150

NETWORK_PROBE_URL=
NETWORK_PROBE_TIMEOUT_SECONDS=3
NETWORK_PROBE_CACHE_SECONDS=20

JWT_SECRET=replace-me-in-production
DATA_MODE=mock
USE_MOCK_DATA=true
SERIAL_ENABLED=false
SERIAL_PORT=
SERIAL_BAUDRATE=115200
SERIAL_PACKET_TYPE=5
SERIAL_MAC_FILTER=535708000000
SERIAL_FALLBACK_DEVICE_MAC=
SERIAL_AUTO_CONFIGURE=true
SERIAL_DISABLE_UUID_OUTPUT=true
SERIAL_APPLY_MAC_FILTER=false
SERIAL_APPLY_PACKET_TYPE=true
SERIAL_ENABLE_BROADCAST_SOS_OVERLAY=true
SERIAL_RESPONSE_CYCLE_SECONDS=8
SERIAL_BROADCAST_CYCLE_SECONDS=2
MQTT_ENABLED=false
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC=t10-gateway
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_KEEPALIVE_SECONDS=60
