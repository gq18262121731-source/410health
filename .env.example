APP_NAME=vision-service
LOG_LEVEL=INFO

DEFAULT_CAMERA_ID=camera_01
DEFAULT_RTSP_URL=rtsp://admin:你的密码@192.168.8.254:10554/tcp/av0_1
ENABLE_DUAL_STREAM=true
MAIN_STREAM_URL=rtsp://admin:你的密码@192.168.8.254:10554/tcp/av0_0
ANALYSIS_STREAM_URL=rtsp://admin:你的密码@192.168.8.254:10554/tcp/av0_1
# Mobile WiFi / camera reboot may change only the host part.
# Use POST /stream/switch-host with the new host instead of editing these values at runtime.
MAIN_CAPTURE_BACKEND=subprocess_opencv
ANALYSIS_CAPTURE_BACKEND=subprocess_opencv
DISPLAY_FALLBACK_TO_ANALYSIS=true
DISPLAY_FALLBACK_FRAME_AGE_MS=1500
DISPLAY_FALLBACK_MIN_HOLD_MS=10000
MOCK_CAMERA_ENABLED=true
MOCK_CAMERA_WIDTH=1280
MOCK_CAMERA_HEIGHT=720
MOCK_CAMERA_FPS=25

DETECTION_ENABLED=true
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE=0.35
YOLO_IMGSZ=512
YOLO_DEVICE=cuda:0
DETECTION_INTERVAL_MS=200

ENABLE_TRACKING=true
ENABLE_IDENTITY=false
ENABLE_TARGET_BINDING=false
IDENTITY_STORE_DIR=data/identities
IDENTITY_MAX_IMAGES=5
INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_CTX_ID=0
INSIGHTFACE_DET_SIZE=640
INSIGHTFACE_PROVIDERS=
IDENTITY_SERVICE_URL=http://127.0.0.1:8100
ENABLE_IDENTITY_BINDING=false
IDENTITY_REQUEST_TIMEOUT_MS=500
IDENTITY_MATCH_INTERVAL_MS=1000
IDENTITY_MATCH_THRESHOLD=0.45
IDENTITY_CROP_PADDING_RATIO=0.12
IDENTITY_BINDING_ASYNC=true
IDENTITY_HEALTH_TTL_MS=5000
IDENTITY_MATCH_TTL_MS=1000
IDENTITY_BINDING_WORKER_FPS=1
IDENTITY_MAX_INFLIGHT=1
TARGET_LOST_AFTER_MS=1000
TARGET_REACQUIRE_AFTER_MS=3000
BYTETRACK_TRACK_HIGH_THRESH=0.5
BYTETRACK_TRACK_LOW_THRESH=0.1
BYTETRACK_NEW_TRACK_THRESH=0.6
BYTETRACK_MATCH_THRESH=0.8
BYTETRACK_TRACK_BUFFER=30
BYTETRACK_FRAME_RATE=10
BYTETRACK_FUSE_SCORE=true

ENABLE_POSE=false
POSE_PROVIDER=mock
POSE_FPS=3
YOLO_POSE_MODEL_PATH=yolov8n-pose.pt
YOLO_POSE_CONFIDENCE=0.25
YOLO_POSE_IMGSZ=320
YOLO_POSE_DEVICE=cuda:0
POSE_CROP_PADDING_RATIO=0.08
POSE_SKIP_WHEN_INFERENCE_BUSY=true
POSE_MAX_INFERENCE_MS=1500
POSE_SLOW_INFERENCE_CIRCUIT_BREAKER_COUNT=3
POSE_CIRCUIT_BREAKER_COOLDOWN_MS=10000

ENABLE_BEHAVIOR=false
BEHAVIOR_RAPID_DESCENT_PX_PER_SEC=260
BEHAVIOR_LONG_STILL_SEC=5
BEHAVIOR_STILL_VELOCITY_PX_PER_SEC=18

TRACKING_WORKER_FPS=12
POSE_WORKER_FPS=2
RESULT_PUBLISH_FPS=10
POSE_RESULT_TTL_MS=1500
BEHAVIOR_RESULT_TTL_MS=1500

WATCHDOG_ENABLED=true
WATCHDOG_CHECK_INTERVAL_MS=1000
WATCHDOG_WORKER_HEARTBEAT_TIMEOUT_MS=5000
WATCHDOG_CAPTURE_STALE_MS=3000
WATCHDOG_MAX_RESTART_COUNT=3
WATCHDOG_RESTART_WINDOW_MS=60000

VIDEO_BRIDGE_ENABLED=false
VIDEO_BRIDGE_URL=http://127.0.0.1:8000/api/v1/video-bridge/analysis
VIDEO_BRIDGE_FALL_EVENT_URL=http://192.168.8.251:18080/api/v1/video-bridge/fall-events
VIDEO_BRIDGE_FPS=1
VIDEO_BRIDGE_TIMEOUT_SECONDS=2

ENABLE_TEMPORAL=false
FEATURE_WINDOW_SIZE=32
UNSTABLE_FRAME_THRESHOLD=3
FALLING_PROB_THRESHOLD=0.65
FALL_CONFIRM_FRAMES=5
FALL_STILL_MS=1500
COOLDOWN_SECONDS=10

RECONNECT_INITIAL_DELAY_SEC=1
RECONNECT_MAX_DELAY_SEC=10
CAPTURE_STALE_TIMEOUT_SEC=3
STREAM_STALE_THRESHOLD_MS=3000
STREAM_STALE_RECONNECT_AFTER_MS=6000
CAPTURE_READ_WARN_MS=500
CAPTURE_READ_STALE_MS=3000
CAPTURE_FORCE_REOPEN_AFTER_SLOW_READS=3
CAPTURE_READ_WATCHDOG_RELEASE_ENABLED=false
CAPTURE_BACKEND=subprocess_opencv
CAPTURE_PROCESS_FRAME_TIMEOUT_MS=2000
CAPTURE_PROCESS_RESTART_MS=500
CAPTURE_IPC_MODE=jpeg_pipe
CAPTURE_JPEG_QUALITY=60
CAPTURE_PROCESS_OUTPUT_HEIGHT=720
CAPTURE_PROCESS_WRITE_FPS=10
MAIN_CAPTURE_JPEG_QUALITY=55
MAIN_CAPTURE_PROCESS_OUTPUT_HEIGHT=720
MAIN_CAPTURE_PROCESS_WRITE_FPS=8
CAPTURE_PROCESS_MAX_RESTARTS=0
OPENCV_CAPTURE_BUFFERSIZE=1
OPENCV_FFMPEG_CAPTURE_OPTIONS=

WEBRTC_STUN_SERVER=stun:stun.l.google.com:19302
WEBRTC_VIDEO_FPS=25
