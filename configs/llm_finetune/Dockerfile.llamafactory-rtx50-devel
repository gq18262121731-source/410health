FROM health-llamafactory-gpu:latest

ARG INSTALL_DEEPSPEED=true
ARG INSTALL_FLASH_ATTN=false
ARG INSTALL_VLLM=false
ARG INSTALL_UNSLOTH=false

ENV DEBIAN_FRONTEND=noninteractive
ENV CUDA_HOME=/usr/local/cuda
ENV PATH="/usr/local/cuda/bin:${PATH}"
ENV LD_LIBRARY_PATH="/usr/local/cuda/lib64:${LD_LIBRARY_PATH}"
ENV MAX_JOBS=4
ENV DS_BUILD_OPS=0
ENV FLASH_ATTENTION_FORCE_BUILD=FALSE
ENV VLLM_WORKER_MULTIPROC_METHOD=spawn
ENV PIP_ROOT_USER_ACTION=ignore

SHELL ["/bin/bash", "-c"]
WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        cuda-nvcc-12-8 cuda-cudart-dev-12-8 cuda-nvrtc-dev-12-8 \
        ninja-build cmake && \
    rm -rf /var/lib/apt/lists/* && \
    nvcc -V

RUN if [ "${INSTALL_DEEPSPEED}" = "true" ]; then \
        DS_BUILD_OPS=0 python -m pip install --no-cache-dir --no-build-isolation -r requirements/deepspeed.txt; \
    fi && \
    if [ "${INSTALL_FLASH_ATTN}" = "true" ]; then \
        python -m pip install --no-cache-dir --no-build-isolation flash-attn; \
    fi && \
    if [ "${INSTALL_VLLM}" = "true" ]; then \
        python -m pip install --no-cache-dir --no-build-isolation -r requirements/vllm.txt; \
    fi && \
    if [ "${INSTALL_UNSLOTH}" = "true" ]; then \
        python -m pip install --no-cache-dir --no-build-isolation unsloth; \
    fi
