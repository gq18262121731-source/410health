FROM nvidia/cuda:12.8.1-base-ubuntu24.04

ARG PIP_INDEX=https://pypi.org/simple
ARG PYTORCH_INDEX=https://download.pytorch.org/whl/cu128
ARG INSTALL_DEEPSPEED=false
ARG INSTALL_VLLM=false
ARG INSTALL_LIGER=true
ARG INSTALL_UNSLOTH=false

ENV DEBIAN_FRONTEND=noninteractive
ENV GRADIO_SERVER_NAME=0.0.0.0
ENV GRADIO_SERVER_PORT=7860
ENV API_PORT=8000
ENV MAX_JOBS=4
ENV DS_BUILD_OPS=0
ENV VLLM_WORKER_MULTIPROC_METHOD=spawn
ENV PIP_ROOT_USER_ACTION=ignore

SHELL ["/bin/bash", "-c"]
WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 python3-pip python3-venv python3-dev \
        build-essential git curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

RUN python3 -m venv /opt/llamafactory && \
    /opt/llamafactory/bin/python -m pip install --no-cache-dir --upgrade pip packaging wheel setuptools editables "hatchling>=1.18.0" && \
    /opt/llamafactory/bin/python -m pip install --no-cache-dir --index-url "${PYTORCH_INDEX}" torch torchvision torchaudio

ENV PATH="/opt/llamafactory/bin:${PATH}"

COPY . /app

RUN python -m pip config set global.index-url "${PIP_INDEX}" && \
    python -m pip config set global.extra-index-url "${PIP_INDEX}" && \
    python -m pip install --no-cache-dir --no-build-isolation -e . && \
    python -m pip install --no-cache-dir --no-build-isolation -r requirements/metrics.txt && \
    if [ "${INSTALL_DEEPSPEED}" = "true" ]; then DS_BUILD_OPS=0 python -m pip install --no-cache-dir --no-build-isolation -r requirements/deepspeed.txt; fi && \
    if [ "${INSTALL_LIGER}" = "true" ]; then python -m pip install --no-cache-dir --no-build-isolation -r requirements/liger-kernel.txt; fi && \
    if [ "${INSTALL_VLLM}" = "true" ]; then python -m pip install --no-cache-dir --no-build-isolation -r requirements/vllm.txt; fi && \
    if [ "${INSTALL_UNSLOTH}" = "true" ]; then python -m pip install --no-cache-dir --no-build-isolation unsloth; fi

EXPOSE 7860 8000
